{
    "name": "sunaoka/aws-sdk-php-structures",
    "description": "Library for converting AWS SDK for PHP parameters and results into typed classes",
    "type": "library",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "sunaoka",
            "email": "sunaoka@pocari.org"
        }
    ],
    "require": {
        "php": "^8.1",
        "aws/aws-sdk-php": "3.379.9"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sunaoka\\Aws\\Structures\\": ["src/classes/", "src/structures/"],
            "Sunaoka\\Aws\\Structures\\Task\\": "task/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "./tests/"
        }
    },
    "config": {
        "audit": {
            "ignore": ["aws/aws-sdk-php"]
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
